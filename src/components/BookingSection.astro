---
import type { BookingConfig } from '../data/resume';
import { getBookingsUrl } from '../lib/bookings';
import MeetY2KGraphic from './MeetY2KGraphic.astro';

interface Props {
  booking: BookingConfig;
  contactEmail: string;
}

const { booking, contactEmail } = Astro.props;

const bookingsUrl = getBookingsUrl();
---

<section
  id="meet"
  class="plm-section-reveal scroll-mt-24 border-t border-plm-ink/10 bg-gradient-to-b from-plm-pink/40 via-plm-white to-plm-paper py-20"
  aria-labelledby="meet-heading"
>
  <div class="mx-auto grid max-w-5xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="plm-sticker">{booking.sticker}</p>
      <h2
        id="meet-heading"
        class="mt-6 font-serif text-4xl font-semibold leading-tight tracking-tight text-plm-ink sm:text-5xl"
      >
        {booking.title}
      </h2>
      <p class="mt-4 max-w-md text-base leading-relaxed text-plm-muted sm:text-lg">
        {booking.description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="plm-btn-mint" href={bookingsUrl} rel="noreferrer" target="_blank"> Book a call </a>
        <a class="plm-btn-outline" href={`mailto:${contactEmail}`}> Email me </a>
      </div>
    </div>

    <MeetY2KGraphic />
  </div>
</section>

---
import { navLinks } from '../data/resume';
import { getBookingsUrl } from '../lib/bookings';

const bookHref = getBookingsUrl();
---

<header
  class="sticky top-0 z-[60] border-b border-plm-ink/10 bg-plm-white/90 shadow-sm backdrop-blur-md transition-shadow duration-300 hover:shadow-md"
>
  <nav
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="group font-serif text-lg font-semibold tracking-tight text-plm-ink transition hover:text-plm-muted sm:text-xl"
      aria-label="Sai — home"
    >
      Sai<span class="plm-brand-heart" aria-hidden="true">❤️</span>
    </a>
    <ul
      class="flex flex-1 flex-wrap items-center justify-center gap-x-1 gap-y-2 font-sans text-xs font-semibold uppercase tracking-wider text-plm-muted sm:gap-x-3 sm:text-[11px]"
    >
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="rounded-full px-2 py-1.5 text-plm-ink/80 transition duration-200 hover:scale-105 hover:bg-plm-pink/50 hover:text-plm-ink"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={bookHref}
      class="inline-flex items-center gap-2 rounded-full bg-plm-mint px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-plm-ink shadow-sm transition duration-200 hover:scale-[1.04] hover:bg-plm-mint-deep active:scale-[0.98] sm:text-[11px]"
      rel="noreferrer"
      target="_blank"
    >
      <span class="h-2 w-2 shrink-0 animate-pulse rounded-full bg-plm-pink-deep" aria-hidden="true" />
      Book a call
    </a>
  </nav>
</header>

---
import { navLinks, resume } from '../data/resume';

const scheduleUrl =
  (import.meta.env.PUBLIC_BOOKING_SCHEDULE_URL as string | undefined)?.trim() ||
  resume.booking.scheduleUrl;
const bookHref = scheduleUrl || '#meet';
---

<header
  class="sticky top-0 z-[60] border-b border-plm-ink/10 bg-plm-white/90 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="font-serif text-xl font-semibold tracking-tight text-plm-ink lowercase hover:text-plm-muted"
    >
      spk.
    </a>
    <ul
      class="flex flex-1 flex-wrap items-center justify-center gap-x-1 gap-y-2 font-sans text-xs font-semibold uppercase tracking-wider text-plm-muted sm:gap-x-3 sm:text-[11px]"
    >
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="rounded-full px-2 py-1.5 text-plm-ink/80 transition hover:bg-plm-pink/50 hover:text-plm-ink"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={bookHref}
      class="inline-flex items-center gap-2 rounded-full bg-plm-mint px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-plm-ink shadow-sm transition hover:bg-plm-mint-deep sm:text-[11px]"
      rel={scheduleUrl ? 'noreferrer' : undefined}
      target={scheduleUrl ? '_blank' : undefined}
    >
      <span class="h-2 w-2 shrink-0 rounded-full bg-plm-pink-deep" aria-hidden="true" />
      Book a call
    </a>
  </nav>
</header>

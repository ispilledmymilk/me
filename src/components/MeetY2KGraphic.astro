---
/* Decorative Y2K collage — no calendar, visual only */
---

<div
  class="meet-y2k relative flex min-h-[420px] w-full items-center justify-center overflow-hidden rounded-[1.75rem] border-2 border-plm-ink/15 bg-gradient-to-br from-plm-pink/90 via-plm-white to-plm-sky/80 p-6 shadow-[inset_0_0_60px_rgb(252_228_236_/_0.35)] sm:min-h-[480px] sm:p-10"
  role="img"
  aria-hidden="true"
>
  <div class="pointer-events-none absolute inset-0 opacity-40" aria-hidden="true">
    <div class="meet-y2k-shine absolute -left-1/4 top-0 h-full w-1/2 rotate-12 bg-gradient-to-r from-transparent via-white to-transparent"></div>
  </div>

  <svg
    class="relative z-[1] w-full max-w-[340px] drop-shadow-[4px_6px_0_rgb(45_42_50_/_0.08)]"
    viewBox="0 0 320 380"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <linearGradient id="meetChrome" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#fce4ec" />
        <stop offset="35%" stop-color="#ffffff" />
        <stop offset="70%" stop-color="#b3e5fc" />
        <stop offset="100%" stop-color="#f8bbd9" />
      </linearGradient>
      <linearGradient id="meetPhone" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#c5e1a5" />
        <stop offset="100%" stop-color="#aed581" />
      </linearGradient>
    </defs>

    <g class="meet-y2k-float">
      <path
        d="M48 52 L62 80 L92 86 L70 106 L76 138 L48 122 L20 138 L26 106 L4 86 L34 80 Z"
        fill="#f8bbd9"
        stroke="#2d2a32"
        stroke-width="1.5"
        opacity="0.95"
      />
    </g>

    <g class="meet-y2k-float-slow">
      <text
        x="160"
        y="48"
        text-anchor="middle"
        fill="#2d2a32"
        font-family="system-ui, sans-serif"
        font-size="11"
        font-weight="800"
        letter-spacing="0.35em"
      >
        XOXO
      </text>
    </g>

    <rect
      x="92"
      y="72"
      width="136"
      height="220"
      rx="22"
      fill="url(#meetPhone)"
      stroke="#2d2a32"
      stroke-width="2.5"
    />
    <rect x="108" y="92" width="104" height="148" rx="6" fill="#fffdf8" stroke="#2d2a32" stroke-width="1.2" />
    <rect x="124" y="252" width="72" height="10" rx="5" fill="#fce4ec" stroke="#2d2a32" stroke-width="1" />
    <circle cx="160" cy="278" r="5" fill="#f8bbd9" stroke="#2d2a32" stroke-width="1" />

    <g class="meet-y2k-twinkle">
      <path d="M248 96 L254 112 L270 112 L258 122 L264 138 L248 128 L232 138 L238 122 L226 112 L242 112 Z" fill="#fff"
        stroke="#2d2a32" stroke-width="1.2" />
    </g>

    <ellipse cx="72" cy="268" rx="36" ry="22" fill="#b3e5fc" stroke="#2d2a32" stroke-width="1.5" opacity="0.9" />
    <text
      x="72"
      y="274"
      text-anchor="middle"
      fill="#2d2a32"
      font-family="system-ui, sans-serif"
      font-size="9"
      font-weight="700"
      letter-spacing="0.12em"
    >
      2000s
    </text>

    <g class="meet-y2k-heart">
      <path
        d="M160 312 C140 298 118 288 118 262 C118 242 132 228 152 228 C158 228 160 232 160 232 C160 232 162 228 168 228 C188 228 202 242 202 262 C202 288 180 298 160 312Z"
        fill="url(#meetChrome)"
        stroke="#2d2a32"
        stroke-width="2"
      />
    </g>

    <text
      x="160"
      y="352"
      text-anchor="middle"
      fill="#2d2a32"
      font-family="Georgia, serif"
      font-size="22"
      font-weight="700"
      letter-spacing="0.02em"
    >
      let’s chat !
    </text>

    <g opacity="0.85">
      <circle cx="40" cy="180" r="4" fill="#f23684" class="meet-y2k-dot" />
      <circle cx="285" cy="200" r="3" fill="#81d4fa" class="meet-y2k-dot meet-y2k-dot-d" />
      <circle cx="270" cy="300" r="3.5" fill="#aed581" class="meet-y2k-dot meet-y2k-dot-b" />
    </g>
  </svg>
</div>

<style>
  @keyframes meet-y2k-shine {
    0% {
      transform: translateX(-20%) skewX(-12deg);
    }
    100% {
      transform: translateX(220%) skewX(-12deg);
    }
  }
  @keyframes meet-y2k-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  @keyframes meet-y2k-twinkle {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
    50% {
      transform: scale(1.08) rotate(8deg);
      opacity: 0.85;
    }
  }
  @keyframes meet-y2k-heart {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.04);
    }
  }
  @keyframes meet-y2k-dot {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 1;
    }
  }

  .meet-y2k-shine {
    animation: meet-y2k-shine 5s ease-in-out infinite;
  }
  .meet-y2k-float {
    animation: meet-y2k-float 4s ease-in-out infinite;
  }
  .meet-y2k-float-slow {
    animation: meet-y2k-float 5.5s ease-in-out infinite;
    animation-delay: -1s;
  }
  .meet-y2k-twinkle {
    transform-origin: 248px 118px;
    animation: meet-y2k-twinkle 2.8s ease-in-out infinite;
  }
  .meet-y2k-heart {
    transform-origin: 160px 270px;
    animation: meet-y2k-heart 2.2s ease-in-out infinite;
  }
  .meet-y2k-dot {
    animation: meet-y2k-dot 1.8s ease-in-out infinite;
  }
  .meet-y2k-dot-b {
    animation-delay: 0.4s;
  }
  .meet-y2k-dot-d {
    animation-delay: 0.8s;
  }

  @media (prefers-reduced-motion: reduce) {
    .meet-y2k-shine,
    .meet-y2k-float,
    .meet-y2k-float-slow,
    .meet-y2k-twinkle,
    .meet-y2k-heart,
    .meet-y2k-dot,
    .meet-y2k-dot-b,
    .meet-y2k-dot-d {
      animation: none !important;
    }
  }
</style>

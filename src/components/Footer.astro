---
import type { Contact } from '../data/resume';

interface Props {
  contact: Contact;
}

const { contact } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="scroll-mt-24 border-t border-plm-ink/10 bg-plm-pink/50 py-16"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div
      class="rounded-[1.75rem] border border-plm-ink/10 bg-plm-white p-8 shadow-[0_16px_48px_-16px_rgb(45_42_50_/_0.15)] sm:p-10"
    >
      <p class="font-serif text-3xl font-semibold tracking-tight text-plm-ink sm:text-4xl">That’s a wrap.</p>
      <p class="mt-3 max-w-prose text-base leading-relaxed text-plm-muted">
        Thanks for stopping by — connect below or book time in the Meet section.
      </p>
      <ul class="mt-8 flex flex-wrap gap-3">
        <li>
          <a class="plm-btn-outline !px-5 !py-2.5 text-xs sm:text-sm" href={`mailto:${contact.email}`}>
            Email
          </a>
        </li>
        <li>
          <a
            class="plm-btn-outline !px-5 !py-2.5 text-xs sm:text-sm"
            href={contact.linkedin.href}
            rel="noreferrer"
            target="_blank"
          >
            {contact.linkedin.label}
          </a>
        </li>
        <li>
          <a
            class="plm-btn-outline !px-5 !py-2.5 text-xs sm:text-sm"
            href={contact.github.href}
            rel="noreferrer"
            target="_blank"
          >
            {contact.github.label}
          </a>
        </li>
        <li>
          <a
            class="plm-btn-pink !px-5 !py-2.5 text-xs sm:text-sm"
            href={`${import.meta.env.BASE_URL}resume.pdf`}
            download
          >
            Resume PDF
          </a>
        </li>
      </ul>
    </div>
    <p class="mt-8 text-center font-mono text-[11px] uppercase tracking-widest text-plm-muted">
      © {year} Sai Pranavi Kasturi · Astro
    </p>
  </div>
</footer>

---
import type { Contact, HeroContent } from '../data/resume';

interface Props {
  hero: HeroContent;
  contact: Contact;
}

const { hero, contact } = Astro.props;
---

<section
  id="top"
  class="relative scroll-mt-24 overflow-hidden border-b border-plm-ink/10 bg-gradient-to-b from-plm-white via-plm-pink/15 to-plm-white/90 py-16 sm:py-24"
  aria-labelledby="hero-heading"
>
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="plm-hero-blob -left-20 top-10 h-56 w-56 bg-plm-pink-deep/50"></div>
    <div class="plm-hero-blob right-0 top-32 h-48 w-48 bg-plm-sky/60"></div>
    <div class="plm-hero-blob bottom-0 left-1/3 h-40 w-40 bg-plm-mint/50"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-4 sm:px-6">
    <div class="pointer-events-none absolute right-4 top-4 hidden sm:block" aria-hidden="true">
      <span class="inline-block text-4xl text-plm-pink-deep/60 transition duration-500 hover:rotate-12">✦</span>
    </div>
    <p class="plm-sticker max-w-lg plm-stagger-1">{hero.sticker}</p>

    <h1
      id="hero-heading"
      class="plm-stagger-2 mt-8 font-serif text-[clamp(2.1rem,5.5vw,3.5rem)] font-semibold leading-[1.12] tracking-tight text-plm-ink"
    >
      {hero.headline.before}
      <mark class="rounded-md bg-plm-pink-deep/90 px-1.5 py-0.5 text-[0.95em] text-plm-ink decoration-0 transition duration-300 hover:bg-plm-pink">
        {hero.headline.highlight}
      </mark>
      {hero.headline.after}
    </h1>

    <p class="plm-stagger-3 mt-6 max-w-2xl text-base leading-relaxed text-plm-muted sm:text-lg">
      {hero.tagline}
    </p>

    <div class="plm-stagger-4 mt-10 flex flex-wrap items-center gap-3">
      <a href="#meet" class="plm-btn-pink"> Book a meeting </a>
      <a href={`mailto:${contact.email}`} class="plm-btn-outline"> Email me </a>
      <a
        href={contact.linkedin.href}
        class="plm-btn-outline"
        rel="noreferrer"
        target="_blank"
      >
        {contact.linkedin.label}
      </a>
      <a
        href={contact.github.href}
        class="plm-btn-outline"
        rel="noreferrer"
        target="_blank"
      >
        {contact.github.label}
      </a>
      <a href={`${import.meta.env.BASE_URL}resume.pdf`} class="plm-btn-mint" download> Resume (PDF) </a>
    </div>
  </div>
</section>

---
import type { ProjectItem } from '../data/resume';

interface Props {
  item: ProjectItem;
  variant: 'pink' | 'sky' | 'mint';
}

const { item, variant } = Astro.props;
const tone =
  variant === 'pink' ? 'plm-card-pink' : variant === 'sky' ? 'plm-card-sky' : 'plm-card-mint';
---

<article class:list={[tone]}>
  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h3 class="font-serif text-xl font-semibold text-plm-ink">{item.name}</h3>
      {item.context && <p class="mt-1 text-sm italic text-plm-muted">{item.context}</p>}
    </div>
    <p class="font-mono text-xs text-plm-muted sm:text-sm">{item.dates}</p>
  </div>
  <div class="mt-3 space-y-3" aria-label="Technologies by category">
    {
      item.stackByCategory.map((group) => (
        <div>
          <p class="font-sans text-[10px] font-semibold uppercase tracking-wider text-plm-muted">
            {group.label}
          </p>
          <ul class="mt-1.5 flex flex-wrap gap-2">
            {group.items.map((tech) => (
              <li
                class="rounded-full border border-plm-ink/10 bg-plm-white/80 px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-wide text-plm-ink"
              >
                {tech}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <ul
    class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-plm-muted marker:text-plm-sky-deep"
  >
    {item.bullets.map((b) => (
      <li>{b}</li>
    ))}
  </ul>
</article>

---
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
}

const { id, title, eyebrow } = Astro.props;
---

<section
  id={id}
  class="plm-section-reveal scroll-mt-24 border-t border-plm-ink/10 py-16 first:border-t-0 first:pt-12"
  aria-labelledby={`${id}-heading`}
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    {eyebrow && <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-plm-muted">{eyebrow}</p>}
    <h2
      id={`${id}-heading`}
      class="mt-2 font-serif text-3xl font-semibold tracking-tight text-plm-ink sm:text-4xl"
    >
      {title}
    </h2>
    <div class="mt-10 space-y-8">
      <slot />
    </div>
  </div>
</section>
